{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "meta": {
    "name": "Join the Movement Design Tokens",
    "version": "0.1.0",
    "source": "codebase/join-the-movement-website/css/main.css"
  },
  "color": {
    "brand": {
      "g1":    { "value": "#A855F7", "comment": "purple" },
      "g2":    { "value": "#6366F1", "comment": "indigo" },
      "g3":    { "value": "#22D3EE", "comment": "cyan" },
      "gPink": { "value": "#E83DF0", "comment": "magenta" },
      "lime":  { "value": "#CCFF00", "comment": "signature accent" }
    },
    "feedback": {
      "danger": { "value": "#FB7185", "comment": "form errors / invalid state" }
    }
  },
  "gradient": {
    "grad":     { "value": "linear-gradient(150deg, #A855F7 0%, #6366F1 52%, #22D3EE 100%)" },
    "gradSoft": { "value": "linear-gradient(150deg, #A855F7, #22D3EE)" }
  },
  "theme": {
    "dark": {
      "bg":              { "value": "#08070D" },
      "bgElev":          { "value": "#0E0C16" },
      "text":            { "value": "#F5F3FA" },
      "textMuted":       { "value": "#A4A0B6" },
      "textFaint":       { "value": "#6F6B82" },
      "cardBg":          { "value": "rgba(255,255,255,0.035)" },
      "cardBg2":         { "value": "rgba(255,255,255,0.055)" },
      "cardBorder":      { "value": "rgba(255,255,255,0.09)" },
      "cardBorderHover": { "value": "rgba(255,255,255,0.22)" },
      "hairline":        { "value": "rgba(255,255,255,0.08)" },
      "fieldBg":         { "value": "rgba(255,255,255,0.04)" },
      "shadow":          { "value": "0 30px 80px -30px rgba(0,0,0,0.7)" },
      "glowBlend":       { "value": "screen" },
      "glowOpacity":     { "value": "0.55" }
    },
    "light": {
      "bg":              { "value": "#FBFAFE" },
      "bgElev":          { "value": "#FFFFFF" },
      "text":            { "value": "#15121F" },
      "textMuted":       { "value": "#5E586E" },
      "textFaint":       { "value": "#9A95AC" },
      "cardBg":          { "value": "rgba(255,255,255,0.7)" },
      "cardBg2":         { "value": "rgba(255,255,255,0.92)" },
      "cardBorder":      { "value": "rgba(22,16,44,0.09)" },
      "cardBorderHover": { "value": "rgba(124,58,237,0.45)" },
      "hairline":        { "value": "rgba(22,16,44,0.08)" },
      "fieldBg":         { "value": "rgba(255,255,255,0.7)" },
      "shadow":          { "value": "0 30px 70px -34px rgba(80,40,160,0.35)" },
      "glowBlend":       { "value": "multiply" },
      "glowOpacity":     { "value": "0.85" }
    }
  },
  "cta": {
    "bg":   { "value": "{color.brand.lime}", "comment": "default; gradient variant uses {gradient.grad}" },
    "ink":  { "value": "#0B0B12" },
    "glow": { "value": "rgba(204,255,0,0.42)" }
  },
  "typography": {
    "fontFamily": {
      "display": { "value": "\"Space Grotesk\", system-ui, sans-serif" },
      "body":    { "value": "\"Hanken Grotesk\", system-ui, sans-serif" }
    },
    "fontWeight": {
      "regular":  { "value": "400" },
      "medium":   { "value": "500" },
      "semibold": { "value": "600" },
      "bold":     { "value": "700" }
    },
    "size": {
      "h1":      { "value": "clamp(2.7rem, 11vw, 5.4rem)" },
      "h2":      { "value": "clamp(2.05rem, 7.5vw, 3.3rem)" },
      "lead":    { "value": "clamp(1.04rem, 2.6vw, 1.22rem)" },
      "eyebrow": { "value": "0.72rem" },
      "stat":    { "value": "clamp(1.5rem, 5vw, 2rem)" }
    },
    "lineHeight": {
      "heading": { "value": "1.04" },
      "body":    { "value": "1.6" },
      "lead":    { "value": "1.55" }
    },
    "letterSpacing": {
      "heading": { "value": "-0.035em" },
      "body":    { "value": "-0.005em" },
      "eyebrow": { "value": "0.32em" }
    }
  },
  "layout": {
    "maxWidth":      { "value": "1140px" },
    "contentWidth":  { "value": "560px", "comment": "720px at >=760px breakpoint" },
    "paddingX":      { "value": "clamp(20px, 6vw, 40px)" },
    "sectionGap":    { "value": "clamp(72px, 12vw, 116px)" }
  },
  "radius": {
    "default": { "value": "22px" },
    "sm":      { "value": "14px" },
    "pill":    { "value": "999px" }
  },
  "breakpoint": {
    "tablet":  { "value": "760px" },
    "desktop": { "value": "1040px" }
  },
  "motion": {
    "easing": {
      "standard": { "value": "cubic-bezier(0.2, 0.7, 0.2, 1)" },
      "reveal":   { "value": "cubic-bezier(0.22, 0.68, 0.2, 1)" }
    },
    "duration": {
      "fast":   { "value": "0.25s" },
      "base":   { "value": "0.35s" },
      "reveal": { "value": "0.85s" }
    }
  }
}
